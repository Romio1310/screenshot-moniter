{
  "manifest_version": 3,
  "name": "Screenshot Monitor",
  "version": "1.0.0",
  "description": "Intelligent Screenshot Monitoring — Capture and monitor browser screenshots automatically.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
